<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_responsibility_type_list" model="ir.ui.view">
        <field name="name">l10n_ve.responsibility.type.list</field>
        <field name="model">l10n_ve.responsibility.type</field>
        <field name="arch" type="xml">
            <list string="Tipos de Responsabilidad SENIAT"
                  decoration-muted="not active"
                  editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_responsibility_type_form" model="ir.ui.view">
        <field name="name">l10n_ve.responsibility.type.form</field>
        <field name="model">l10n_ve.responsibility.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Responsabilidad SENIAT">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_responsibility_type" model="ir.actions.act_window">
        <field name="name">Tipos de Responsabilidad SENIAT</field>
        <field name="res_model">l10n_ve.responsibility.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_responsibility_type"
              name="Responsabilidad SENIAT (VE)"
              action="action_responsibility_type"
              parent="contacts.menu_localisation"
              sequence="42"/>
</odoo>
