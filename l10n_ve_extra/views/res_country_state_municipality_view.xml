<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipality_list" model="ir.ui.view">
        <field name="name">res.country.state.municipality.list</field>
        <field name="model">res.country.state.municipality</field>
        <field name="arch" type="xml">
            <list string="Municipios">
                <field name="code"/>
                <field name="name"/>
                <field name="state_id" options="{'no_create': True}"/>
            </list>
        </field>
    </record>

    <record id="view_municipality_form" model="ir.ui.view">
        <field name="name">res.country.state.municipality.form</field>
        <field name="model">res.country.state.municipality</field>
        <field name="arch" type="xml">
            <form string="Municipio">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="state_id" options="{'no_create': True}"/>
                    </group>
                    <notebook>
                        <page string="Parroquias">
                            <field name="parish_ids">
                                <list editable="bottom">
                                    <field name="code"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_municipality" model="ir.actions.act_window">
        <field name="name">Municipios</field>
        <field name="res_model">res.country.state.municipality</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_parish_list" model="ir.ui.view">
        <field name="name">res.country.state.municipality.parish.list</field>
        <field name="model">res.country.state.municipality.parish</field>
        <field name="arch" type="xml">
            <list string="Parroquias">
                <field name="code"/>
                <field name="name"/>
                <field name="municipality_id" options="{'no_create': True}"/>
            </list>
        </field>
    </record>

    <record id="view_parish_form" model="ir.ui.view">
        <field name="name">res.country.state.municipality.parish.form</field>
        <field name="model">res.country.state.municipality.parish</field>
        <field name="arch" type="xml">
            <form string="Parroquia">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="municipality_id" options="{'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_parish" model="ir.actions.act_window">
        <field name="name">Parroquias</field>
        <field name="res_model">res.country.state.municipality.parish</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_municipality"
              name="Municipios (VE)"
              action="action_municipality"
              parent="contacts.menu_localisation"
              sequence="40"/>
    <menuitem id="menu_parish"
              name="Parroquias (VE)"
              action="action_parish"
              parent="contacts.menu_localisation"
              sequence="41"/>
</odoo>
