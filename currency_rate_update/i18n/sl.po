#. module: currency_rate_update
#: model_terms:ir.ui.view,arch_db:currency_rate_update.res_currency_rate_provider_form_view
msgid ""
"<strong>!</strong>\n"
"                                You are using European Central Bank exchange "
"rate\n"
"                                service with a base currency different from "
"EUR.\n"
"                                <br/>\n"
"                                As long as the European Central Bank only "
"provides\n"
"                                exchange rates based on EUR, other foreign "
"currency\n"
"                                rates are recalculated and might differ from "
"real rates."
msgstr ""
"<strong>!</strong>\n"
"                                Uporabljate storitev menjalnih tečajev "
"Evropske centralne banke\n"
"                                z osnovno valuto, ki ni EUR.\n"
"                                <br/>\n"
"                                Dokler Evropska centralna banka zagotavlja\n"
"                                menjalne tečaje le na osnovi EUR, se tečaji "
"drugih tujih valut\n"
"                                preračunajo in se lahko razlikujejo od "
"dejanskih tečajev."

