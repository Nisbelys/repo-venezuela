<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Clientes — un cron independiente por zona, para que el timeout
             o una falla en una zona no retrase ni bloquee a las demás.
        ================================================================ -->
        <record id="cron_mikrowisp_sync_caracas" model="ir.cron">
            <field name="name">Mikrowisp: Sincronizar clientes — Caracas</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">env['mikrowisp.sync.caracas'].cron_sync_clients()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

        <record id="cron_mikrowisp_sync_llanos" model="ir.cron">
