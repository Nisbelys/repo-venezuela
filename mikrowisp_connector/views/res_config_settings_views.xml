<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_mikrowisp_form" model="ir.ui.view">
        <field name="name">res.config.settings.mikrowisp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Mikrowisp" name="mikrowisp_connector" data-string="Mikrowisp">

                    <block title="Zona Caracas" name="mikrowisp_caracas_block">
                        <setting string="URL del servidor">
                            <field name="mikrowisp_url" class="w-100" placeholder="https://caracas.wct.com.ve"/>
                        </setting>
                        <setting string="Token API">
                            <field name="mikrowisp_token" password="True" class="w-100"/>
                        </setting>
                        <setting string="Sincronización manual">
                            <button name="action_mikrowisp_sync_caracas"
                                    string="Sincronizar Caracas"
                                    type="object"
                                    class="btn btn-primary"
                                    icon="fa-refresh"/>
                        </setting>
                        <setting string="Facturas (facturado y cobrado)"
                                 help="La primera vez trae el último año; luego solo trae facturas nuevas o recientes.">
                            <button name="action_mikrowisp_sync_facturas_caracas"
                                    string="Sincronizar facturas Caracas"
                                    type="object"
                                    class="btn btn-secondary"
                                    icon="fa-file-text-o"/>
                        </setting>
                    </block>

                    <block title="Zona Los Llanos" name="mikrowisp_llanos_block">
                        <setting string="URL del servidor">
                            <field name="mikrowisp_llanos_url" class="w-100" placeholder="https://llanos.wct.com.ve"/>
                        </setting>
                        <setting string="Token API">
                            <field name="mikrowisp_llanos_token" password="True" class="w-100"/>
                        </setting>
                        <setting string="Sincronización manual">
                            <button name="action_mikrowisp_sync_llanos"
                                    string="Sincronizar Los Llanos"
                                    type="object"
                                    class="btn btn-primary"
                                    icon="fa-refresh"/>
                        </setting>
                        <setting string="Facturas (facturado y cobrado)"
                                 help="La primera vez trae el último año; luego solo trae facturas nuevas o recientes.">
                            <button name="action_mikrowisp_sync_facturas_llanos"
                                    string="Sincronizar facturas Los Llanos"
                                    type="object"
                                    class="btn btn-secondary"
                                    icon="fa-file-text-o"/>
                        </setting>
                    </block>

                    <block title="Zona Puente Hierro" name="mikrowisp_puentehierro_block">
                        <setting string="URL del servidor">
                            <field name="mikrowisp_puentehierro_url" class="w-100" placeholder="https://puentehierro.wct.com.ve"/>
                        </setting>
                        <setting string="Token API">
                            <field name="mikrowisp_puentehierro_token" password="True" class="w-100"/>
                        </setting>
                        <setting string="Sincronización manual">
                            <button name="action_mikrowisp_sync_puentehierro"
                                    string="Sincronizar Puente Hierro"
                                    type="object"
                                    class="btn btn-primary"
                                    icon="fa-refresh"/>
                        </setting>
                        <setting string="Facturas (facturado y cobrado)"
                                 help="La primera vez trae el último año; luego solo trae facturas nuevas o recientes.">
                            <button name="action_mikrowisp_sync_facturas_puentehierro"
                                    string="Sincronizar facturas Puente Hierro"
                                    type="object"
                                    class="btn btn-secondary"
                                    icon="fa-file-text-o"/>
                        </setting>
                    </block>

                    <block title="Zona Ocumare" name="mikrowisp_ocumare_block">
                        <setting string="URL del servidor">
                            <field name="mikrowisp_ocumare_url" class="w-100" placeholder="https://ocumare.wct.com.ve"/>
                        </setting>
                        <setting string="Token API">
                            <field name="mikrowisp_ocumare_token" password="True" class="w-100"/>
                        </setting>
                        <setting string="Sincronización manual">
                            <button name="action_mikrowisp_sync_ocumare"
                                    string="Sincronizar Ocumare"
                                    type="object"
                                    class="btn btn-primary"
                                    icon="fa-refresh"/>
                        </setting>
                        <setting string="Facturas (facturado y cobrado)"
                                 help="La primera vez trae el último año; luego solo trae facturas nuevas o recientes.">
                            <button name="action_mikrowisp_sync_facturas_ocumare"
                                    string="Sincronizar facturas Ocumare"
                                    type="object"
                                    class="btn btn-secondary"
                                    icon="fa-file-text-o"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
