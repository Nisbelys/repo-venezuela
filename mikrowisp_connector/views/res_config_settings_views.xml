<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_mikrowisp_form" model="ir.ui.view">
        <field name="name">res.config.settings.mikrowisp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="before">
                <div class="app_settings_block">
                    <h2>Mikrowisp</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label fw-bold">Conexión API</span>
                                <div class="text-muted mb-2">
                                    Credenciales del sistema Mikrowisp (solo lectura).
                                </div>
                                <div class="content-group">
                                    <div class="mt8">
                                        <label for="mikrowisp_url" string="URL del servidor"/>
                                        <field name="mikrowisp_url" class="w-100"/>
                                    </div>
                                    <div class="mt8">
                                        <label for="mikrowisp_token" string="Token API"/>
                                        <field name="mikrowisp_token" password="True" class="w-100"/>
                                    </div>
                                    <div class="mt16">
                                        <button name="action_mikrowisp_sync_now"
                                                string="Sincronizar ahora"
                                                type="object"
                                                class="btn btn-primary"
                                                icon="fa-refresh"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
